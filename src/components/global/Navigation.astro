<header
    class="relative flex flex-col w-full mx-auto md:items-center md:justify-between md:flex-row"
>
    <div
        class="flex flex-row items-center justify-between py-2 md:justify-start"
    >
        <a class="text-base font-medium tracking-tight" href="/">
            <em class="font-bold text-base-900">NUVOLIC</em>
            <span class="text-base-500 text-xs font-normal ml-1">(a blog)</span>
        </a>
        <button
            id="menu-button"
            class="inline-flex items-center justify-center p-2 text-base-500 hover:text-base-900 focus:outline-none focus:text-base-900 md:hidden"
            aria-controls="site-menu"
            aria-expanded="false"
        >
            <span class="sr-only">Open menu</span>
            <svg
                class="w-6 h-6"
                stroke="currentColor"
                fill="none"
                viewBox="0 0 24 24"
                aria-hidden="true"
            >
                <path
                    class="menu-open"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
                <path
                    class="menu-close hidden"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>
    <nav
        id="site-menu"
        class="hidden flex-col justify-center flex-grow py-12 md:py-0 md:flex md:items-end md:flex-row"
    >
        <div
            class="items-center justify-center list-none space-y-2 md:space-y-0 md:ml-auto md:inline-flex md:text-left gap-3"
        >
            <a href="/tags" class="text-base-500 hover:text-base-900 text-sm"
                >Tags</a
            >
            <a
                href="/rss.xml"
                class="text-base-500 hover:text-base-900 text-sm"
            >
                RSS
            </a>
        </div>
    </nav>
</header>

<script>
    const button = document.querySelector("#menu-button");
    const menu = document.querySelector("#site-menu");
    const openIcon = document.querySelector(".menu-open");
    const closeIcon = document.querySelector(".menu-close");

    button?.addEventListener("click", () => {
        const expanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!expanded));
        menu?.classList.toggle("hidden");
        menu?.classList.toggle("flex");
        openIcon?.classList.toggle("hidden");
        closeIcon?.classList.toggle("hidden");
    });
</script>
