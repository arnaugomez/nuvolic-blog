---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())].sort();
---

<BaseLayout title="Tags | NUVOLIC (a blog)">
  <section>
    <div class="py-24">
      <h1 class="text-4xl text-balance font-medium font-display text-base-900 max-w-xl">All tags</h1>
      <div class="flex flex-wrap gap-3 mt-8">
        {
          tags.map((tag) => (
            <a class="text-xs font-medium text-base-500 hover:text-base-900" href={`/tags/${tag}`}>
              {tag}
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
