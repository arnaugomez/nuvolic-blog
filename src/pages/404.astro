    <h1 class="text-4xl text-balance font-medium font-display text-base-900 max-w-xl">Page not found</h1>
    <p class="mt-4 text-sm text-base-500 max-w-md">The page you are looking for does not exist.</p>
    <a href="/" class="inline-flex mt-8 text-sm font-medium text-base-900 underline hover:text-blue-600">Back to the blog</a>
  </section>
</BaseLayout>
